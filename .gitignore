# =============================================================================
# PYTHON GITIGNORE
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST
wheels/
pip-wheel-metadata/
share/python-wheels/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
coverage.xml
*.cover
.hypothesis/

# Environments
.env
.envrc
.venv
env/
venv/
ENV/
.worktrees/

# uv
.uv/

# Python version file
.python-version

# Tool caches
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pytest_cache/
.pytype/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Log files
*.log

# Secrets (never commit)
*.pem
*.key
.env.local
.env.*.local

# =============================================================================
# BENCHMARK OUTPUTS
# =============================================================================
runs/
*.jsonl
*.parquet
traces/

# NOTE: uv.lock is NOT ignored - it should be committed for reproducible builds
# NOTE: pyproject.toml is NOT ignored - it's the project configuration

# Orchestration logs
.implement/
